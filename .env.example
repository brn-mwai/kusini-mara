# ─────────────────────────────────────────────────────────────────────────────
# Kusini — environment template. Copy to .env.local in each app and to the
# Convex dashboard for backend vars. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Convex (both apps point at the SAME deployment — this is the linkage) ──────
# From `npx convex dev` output / Convex dashboard.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
# Backend-only: set in Convex dashboard, used by `convex deploy` in CI.
CONVEX_DEPLOY_KEY=

# ── Clerk auth (separate Clerk instance is fine; one is simplest) ─────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx
# The Clerk JWT issuer domain — Convex validates tokens against this.
# Clerk dashboard → JWT Templates → create "convex" template → Issuer URL.
CLERK_JWT_ISSUER_DOMAIN=https://your-instance.clerk.accounts.dev

# ── Notifications port ────────────────────────────────────────────────────────
# Africa's Talking SMS = the guaranteed channel + escalation backbone.
# Leave blank to run SMS-only-mock (escalations still logged to notifications).
AFRICASTALKING_USERNAME=
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=KUSINI
# Airline ops + lodge backup numbers escalations dial when creds present.
ESCALATION_AIRLINE_OPS_PHONE=

# WhatsApp = preference channel (Twilio). Mocked when blank.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# ── Escalation tuning ─────────────────────────────────────────────────────────
# Minutes before scheduled_time that an unacknowledged movement escalates.
ESCALATION_WINDOW_MINUTES=120

# ── Observability (env-gated; stubbed when absent — never fatal) ──────────────
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
